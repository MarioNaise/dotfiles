[user]
	email = 102912402+MarioNaise@users.noreply.github.com
	name = MarioNaise
[alias]
	aa = add .
  b = branch
  bd = branch -D
	c = commit
	cm = commit -m
	ca = commit --amend
	can = commit --amend --no-edit
	d = diff
	ds = diff --staged
	s = status
	r = reset
	rh = reset --hard
  re = rebase
  rea = rebase --abort
  rec = rebase --continue
  rei = rebase -i
  sw = switch
  sc = switch -c
  st = stash
  sta = stash apply
  std = stash drop
  stl = stash list
  stm = stash -m
  stp = stash pop
  sts = stash show -p
[core]
	excludesfile = ~/.gitignore
	editor = nvim
[rerere]
	enabled = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
